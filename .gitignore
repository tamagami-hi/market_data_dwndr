# Secrets & config
.env
.env.local

# Captured data — never commit
MARKET_DATA/
z_market_data/
*.bin
*.bin.zst

# Python
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
out/
dist/

# OS / editor
.DS_Store
*.log

# Local/VPS release state (images and data remain outside Git)
release_manager/rollback/*
!release_manager/rollback/.gitkeep
release_manager/current-version
release_manager/.operation.lock
release_manager/.bundle-stage.*
release_manager/recent_builds/*
!release_manager/recent_builds/.gitkeep
release_manager/DATA_DOWNLOADER/docker-compose.yml
release_manager/DATA_DOWNLOADER/manifest.json
release_manager/DATA_DOWNLOADER/manifest.sig
release_manager/DATA_DOWNLOADER/version.json
release_manager/DATA_DOWNLOADER/images/*
!release_manager/DATA_DOWNLOADER/images/.gitkeep

# Obsidian workspace (keep notes, ignore local UI state)
.obsidian/workspace*
.obsidian/cache
