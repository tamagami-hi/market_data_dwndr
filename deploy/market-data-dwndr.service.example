[Unit]
Description=Market data downloader Docker Compose stack
Documentation=https://github.com/tamagami-hi/market_data_dwndr
Wants=network-online.target docker.service tailscaled.service
Requires=docker.service
After=network-online.target docker.service tailscaled.service
RequiresMountsFor=/srv/dev_stack /srv/data
ConditionPathExists=/srv/dev_stack/market_data_dwndr/compose.yaml

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/srv/dev_stack/market_data_dwndr
Environment=PROJECT_DIR=/srv/dev_stack/market_data_dwndr
ExecStartPre=/srv/dev_stack/market_data_dwndr/deploy/preflight.sh
ExecStart=/usr/bin/docker compose --env-file backend/.env --env-file frontend/.env.local up -d --no-build --remove-orphans
ExecStop=/usr/bin/docker compose --env-file backend/.env --env-file frontend/.env.local stop
TimeoutStartSec=180
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
