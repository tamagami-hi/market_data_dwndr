# =============================================================================
# DATA_DOWNLOADER — production environment (VPS)
# =============================================================================
# Copy this file to `.env` ON THE VPS and fill every value once. The real `.env`
# is NEVER shipped and is PRESERVED across updates (deploys only sync images +
# compose + this template, never your `.env`). Keep it 0600 and owned by the
# deploy user. This single file configures both the backend and the frontend
# runtime.
#
# Backend and frontend run on the SAME machine, so — exactly like local dev —
# they talk over localhost and the same images work locally and on the VPS. No
# fixed IP is required: reach the UI on the box or via an SSH tunnel, e.g.
#   ssh -L 3789:localhost:3789 -L 9000:localhost:9000 beonedge@<vps>
#   then open http://localhost:3789 in your browser.
# When you later get a static IP/domain, set NEXT_PUBLIC_BACKEND_URL + FRONTEND_URL
# to it (rebuild the frontend for the new NEXT_PUBLIC_BACKEND_URL) and point
# HOST_BIND_ADDRESS at the public interface.
#
# After editing, deploy from the build machine with:
#   ./release_manager/deploy.sh --ship ~/.ssh/beonedge_vps
# =============================================================================

# --- release image tag (managed by the deploy script; do not edit by hand) ---
# The deploy script pins this to the release_id it just loaded so Compose
# resolves the exact immutable images. Leave as-is on a fresh checkout.
APP_VERSION=local

# --- required: Kite Connect app credentials ---------------------------------
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret

# --- required: host data roots (env-driven; bind-mounted r/w into the container)
# SSD live capture root and the separate durable archive root. These MUST already
# exist on the VPS, be owned by APP_UID:APP_GID, and live OUTSIDE the deploy folder
# (which is replaced on every update). Bind-mounted at the SAME path in-container.
MARKET_DATA_PATH=/srv/dev_stack/MARKET_DATA
ARCHIVE_DATA_PATH=/srv/data/DATA_DOWNLOADER/ARCHIVE

# --- incoming release image store (env-driven VPS path) -----------------------
# The path where the new images (tar.gz files) will reside when shipped.
# This is used by deploy.sh to load the new images.
RELEASE_IMAGE_PATH=/srv/dev_stack/DATA_DOWNLOADER/images

# --- rollback image store (env-driven VPS path) -----------------------------
# On every update the deploy script `docker save`s the CURRENTLY running images
# here as <ROLLBACK_IMAGE_PATH>/<release_id>/{backend,frontend}.tar.gz BEFORE
# loading the new ones, so a rollback works even after image pruning. Must exist
# and be writable by the deploy user.
ROLLBACK_IMAGE_PATH=/srv/backup/DATA_DOWNLOADER/ROLLBACKS

# --- networking (localhost / same-machine, like local dev) -------------------
# IN-CONTAINER bind address for uvicorn. In Docker this MUST be 0.0.0.0, or the
# published port cannot reach the app. Host exposure is set by HOST_BIND_ADDRESS.
HTTP_HOST=0.0.0.0
HTTP_PORT=9000
# Frontend serve port.
PORT=3789
# The ONLY host address both services publish on. Loopback keeps it private and is
# reached via the SSH tunnel above (recommended now). Set to 0.0.0.0 to expose on
# the office LAN, or to your static IP later. NOTE: 0.0.0.0 puts the unauthenticated
# API on the network — only do that on a trusted/whitelisted network.
HOST_BIND_ADDRESS=127.0.0.1
# Non-root container identity; MARKET_DATA_PATH/ARCHIVE_DATA_PATH must be owned by it.
APP_UID=10001
APP_GID=10001
# Browser origin allowed by CORS + WebSocket. Same machine → localhost, matching the
# tunnel/on-box browser and the frontend PORT. Change to the static IP/domain later.
FRONTEND_URL=http://localhost:3789

# --- automated login (seeded so the daily automation runs unattended) --------
KITE_TOKEN_BROKER_URL=https://calspread.online/api/kite/token
KITE_TOKEN_BROKER_PASSCODE=replace_with_the_rotated_shared_passcode
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
# Daily risk-free rate broker (reuses KITE_TOKEN_BROKER_PASSCODE as x-token-passcode);
# returns a percent, converted to a decimal by the backend.
KITE_RATE_BROKER_URL=https://calspread.online/api/rf
# Fallback risk-free rate (decimal) used only if the rate broker is unavailable.
RISK_FREE_RATE=0.064

# --- release drain lease (required by the deploy script) ---------------------
# Generate once: openssl rand -hex 32
# Authenticates X-Release-Maintenance-Token so the deploy can flush writers.
RELEASE_MAINTENANCE_TOKEN=replace_with_at_least_32_url_safe_characters
RELEASE_MAINTENANCE_TTL_SECONDS=900

# --- egress / static IP (Kite static-IP whitelist, Apr 2026) -----------------
KITE_STATIC_IP=
KITE_HTTP_PROXY=

# --- optional (locked defaults shown) ----------------------------------------
INDICES=NIFTY,BANKNIFTY,FINNIFTY,SENSEX
# Comma-separated NSE/BSE closure dates (YYYY-MM-DD); update before each year.
MARKET_HOLIDAYS=
STOCK_UNIVERSE=all
CAPTURE_HZ=1
ZSTD_LEVEL=17
# EOD compression worker threads per file (1..6).
ZSTD_THREADS=6
AUTH_POLL_START=08:30
AUTH_POLL_END=09:00
AUTH_POLL_INTERVAL_SECONDS=60
MARKET_OPEN=09:00
MARKET_CLOSE=15:30
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO

# NOTE: the daily Kite access_token is obtained by the automation / `md-login`
# and stored in session state under MARKET_DATA_PATH; it is never set here.
