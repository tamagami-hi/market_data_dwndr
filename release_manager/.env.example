# Copy to release_manager/.env on the build/operator machine. The real file is
# git-ignored and is never included in a DATA_DOWNLOADER release bundle. It only
# tells the build machine where and how to ship.

# SSH login for the VPS. Any reachable host or IP works — no Tailscale requirement.
# Deploy with:  ./release_manager/deploy.sh --ship ~/.ssh/beonedge_vps
VPS_SSH_USER=your_vps_username
VPS_SSH_HOST=your_vps_ip_address

# Absolute path of the self-contained deploy folder on the VPS. The whole
# DATA_DOWNLOADER bundle (images + compose + runners) is rsynced here; the VPS
# `.env` inside it is PRESERVED across updates and never overwritten.
VPS_DEPLOY_DIR=/path/to/your/deployable/folder
