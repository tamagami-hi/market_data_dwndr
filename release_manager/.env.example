# Copy to release_manager/.env on the build/operator machine. The real file is
# ignored and is never included in DATA_DOWNLOADER release bundles.
VPS_SSH_USER=beonedge
VPS_SSH_HOST=TAILSCALE_IP_OR_HOSTNAME
VPS_PROJECT_DIR=/srv/dev_stack/market_data_dwndr

# Generate once on the trusted build machine:
#   openssl genpkey -algorithm ED25519 -out /secure/release-private.pem
#   openssl pkey -in /secure/release-private.pem -pubout -out /secure/release-public.pem
# Keep the private key off the VPS. Copy only the public key there.
RELEASE_SIGNING_PRIVATE_KEY=/secure/path/release-private.pem
RELEASE_SIGNING_PUBLIC_KEY=/secure/path/release-public.pem
