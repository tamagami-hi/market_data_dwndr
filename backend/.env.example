# market_data_dwndr backend configuration.
# Copy to `.env` and fill in. `.env` is gitignored -- never commit secrets.
# (This repo only ships this example file; provide the real .env at deploy time.)
# See docs/60-operations/config-and-env.md.

# --- required ---
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
MARKET_DATA_PATH=/data/MARKET_DATA
# Separate durable archive root. EOD compression mirrors the live relative layout here.
ARCHIVE_DATA_PATH=/data/z_market_data
# Optional: directory for persisted monitor statistics JSON (compression history +
# daily capture snapshots). Leave unset to default to MARKET_DATA_PATH/_state/stats.
STATS_DATA_PATH=/data/MARKET_DATA/_state/stats

# --- networking (required; ports come ONLY from here, no code defaults) ---
# Image tag managed by release_manager/deploy.sh. Leave `local` for manual builds.
APP_VERSION=local
# In Docker this is the IN-CONTAINER bind address and MUST be 0.0.0.0, otherwise the
# published port cannot reach uvicorn (127.0.0.1 only works for bare-metal `md-serve`).
# Host exposure is controlled by HOST_BIND_ADDRESS below, not by this value.
HTTP_HOST=0.0.0.0
HTTP_PORT=9000
# Docker publishes both services only on this host address. On the VPS keep this as the
# Tailscale IP (e.g. 100.x.y.z) or 127.0.0.1 — never 0.0.0.0 on a public interface.
HOST_BIND_ADDRESS=127.0.0.1
# Non-root container identity. The two host data directories must be owned by this id.
APP_UID=10001
APP_GID=10001
# Browser page origin(s) allowed by CORS + WebSocket (comma-separate for multiple). This
# is the origin serving the FRONTEND page, not NEXT_PUBLIC_BACKEND_URL. On the VPS set it
# to the Tailscale URL the browser uses, e.g. http://100.122.85.101:3789 — a mismatch
# causes WebSocket 403s and blocked CORS. Must match the frontend PORT below.
FRONTEND_URL=http://localhost:3000

# --- automated login (seeded here so `md-login` can run without a browser) ---
# Optional shared-session lookup. Set both values together. The broker is checked first;
# only an explicit `authenticated: false` falls back to the local credentials below.
KITE_TOKEN_BROKER_URL=https://calspread.online/api/kite/token
KITE_TOKEN_BROKER_PASSCODE=replace_with_a_rotated_random_secret
# The broker token must belong to the same KITE_API_KEY configured above.
# Zerodha login id (e.g. AB1234) and password.
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
# The TOTP is always entered by the user in the frontend or terminal.
# Daily risk-free rate broker (reuses KITE_TOKEN_BROKER_PASSCODE as x-token-passcode).
# Returns the rate as a percent, e.g. {"rf": 5.3324}; the backend converts to a decimal.
KITE_RATE_BROKER_URL=https://calspread.online/api/rf
# Fallback risk-free rate (decimal, e.g. 0.068) used only when the rate broker above is
# unavailable. The daily value is normally fetched from KITE_RATE_BROKER_URL.
RISK_FREE_RATE=

# --- internal release drain API ---
# Generate with `openssl rand -hex 32`; use the same secret in the release manager.
# It is accepted only in X-Release-Maintenance-Token and is never returned or logged.
RELEASE_MAINTENANCE_TOKEN=replace_with_at_least_32_random_characters
# A crashed deployment cannot block capture forever (allowed range: 30..900 seconds).
RELEASE_MAINTENANCE_TTL_SECONDS=900

# --- egress / static IP (Kite requires a whitelisted static IP from Apr 2026) ---
# Bind outbound Kite API calls to the host's static IP (source address), and/or route
# them through a proxy that egresses from the static IP. Leave blank in local dev.
KITE_STATIC_IP=
KITE_HTTP_PROXY=

# --- optional (locked defaults shown) ---
INDICES=NIFTY,BANKNIFTY,FINNIFTY,SENSEX
# Comma-separated NSE/BSE closure dates (YYYY-MM-DD). Update before each calendar year.
MARKET_HOLIDAYS=
STOCK_UNIVERSE=all
CAPTURE_HZ=1
ZSTD_LEVEL=17
# EOD compression worker threads per file (1..6). Higher = faster multithreaded zstd.
ZSTD_THREADS=6
# Trading-day automation: poll shared token in [08:30, 09:00), capture in [09:00, 15:30).
AUTH_POLL_START=08:30
AUTH_POLL_END=09:00
AUTH_POLL_INTERVAL_SECONDS=60
MARKET_OPEN=09:00
MARKET_CLOSE=15:30
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO

# NOTE: the daily Kite access_token is retrieved or obtained by `md-login` and stored in
# session state (see docs/60-operations/session-state.md); it is never set here.
