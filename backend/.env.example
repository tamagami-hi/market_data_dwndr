# market_data_dwndr backend configuration.
# Copy to `.env` and fill in. `.env` is gitignored -- never commit secrets.
# (This repo only ships this example file; provide the real .env at deploy time.)
# See docs/60-operations/config-and-env.md.

# --- required ---
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
MARKET_DATA_PATH=/data/MARKET_DATA

# --- automated login (seeded here so `md-login` can run without a browser) ---
# Zerodha login id (e.g. AB1234) and password.
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
# Optional base32 TOTP secret. If omitted, `md-login` prompts for the 6-digit
# code in the terminal instead of generating it.
KITE_TOTP_SECRET=
# 10-yr bond yield as a decimal (e.g. 0.0691) stamped into file headers. If unset,
# `md-login` prompts for it. Kept out of session files intentionally.
RISK_FREE_RATE=

# --- egress / static IP (Kite requires a whitelisted static IP from Apr 2026) ---
# Bind outbound Kite API calls to the host's static IP (source address), and/or route
# them through a proxy that egresses from the static IP. Leave blank in local dev.
KITE_STATIC_IP=
KITE_HTTP_PROXY=

# --- optional (locked defaults shown) ---
INDICES=NIFTY,BANKNIFTY,FINNIFTY,SENSEX
STOCK_UNIVERSE=all
CAPTURE_HZ=1
ZSTD_LEVEL=17
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
HTTP_PORT=8000

# NOTE: the daily Kite access_token is obtained by `md-login` and stored in session
# state (see docs/60-operations/session-state.md); it is never set here.
