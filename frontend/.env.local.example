# Copy to .env.local. This file is the single source for the frontend's config;
# `npm run dev` / `npm run start` load it (via dotenv-cli) so PORT takes effect.

# Backend origin (scheme + host + port). All backend HTTP + WebSocket URLs are derived
# from this. The port MUST match the backend's HTTP_PORT, and this origin MUST be listed
# in the backend's FRONTEND_URL (CORS). Required — there is no hardcoded fallback.
NEXT_PUBLIC_BACKEND_URL=http://localhost:9000

# Port the frontend serves on. Change this value if the port is already in use
# (that is what an "EADDRINUSE :::3000" error means). No port is hardcoded in the
# scripts — the server binds whatever PORT is set here.
PORT=3000
