# Copy to .env.local. Points the frontend at the FastAPI backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Port the frontend serves on (default 3000). This is read from the *process*
# environment by the npm scripts (`next dev -p ${PORT:-3000}`), so export it in your
# shell / Docker / systemd env rather than relying on this file, e.g.:
#   PORT=4000 npm run dev
# PORT=3000
