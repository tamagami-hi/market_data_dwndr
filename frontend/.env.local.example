# Copy to .env.local. This file is the single source for the frontend's config;
# `npm run dev` / `npm run start` load it (via dotenv-cli) so PORT takes effect.

# Backend/API origin (scheme + host + port). All backend HTTP + WebSocket URLs are
# derived from this and its port MUST match HTTP_PORT. The backend's FRONTEND_URL is
# instead the origin serving this frontend page, because that is the browser's Origin.
#
# IMPORTANT: this value is baked into the frontend image at BUILD time (Next inlines
# NEXT_PUBLIC_* at build). To build an image for the VPS, set this to the browser-facing
# Tailscale URL BEFORE running release_manager/export.sh, e.g. http://100.122.85.101:9000
NEXT_PUBLIC_BACKEND_URL=http://localhost:9000

# Product display name shown in the UI (title, nav, landing). Baked at build time.
NEXT_PUBLIC_APP_NAME=TickVault

# Port the frontend serves on. Must match the backend's FRONTEND_URL port. Change this
# value if the port is already in use ("EADDRINUSE"). No port is hardcoded in the scripts.
PORT=3789

# Dedicated port for the production-build browser test. Keep it different from PORT
# so the test can run while the local development server is active.
E2E_FRONTEND_PORT=13999
