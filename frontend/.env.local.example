# Copy to .env.local. All backend HTTP + WebSocket URLs are derived from this.
#
# Point it at the backend origin (scheme + host + port). The port MUST match the
# backend's HTTP_PORT, and this origin MUST be listed in the backend's FRONTEND_URL
# (CORS). There is no hardcoded fallback — this variable is required.
NEXT_PUBLIC_BACKEND_URL=http://localhost:9000

# Port the frontend serves on. Read from the *process* environment by the npm scripts
# (`next dev -p ${PORT:-3000}`), so export it in your shell / Docker / systemd env:
#   PORT=3000 npm run dev
# PORT=3000
